{% extends '@MauticCore/Default/content.html.twig' %}

{% block mauticContent %}internalemail{% endblock %}

{% block headerTitle %}{{ item.lead.primaryIdentifier }}{% endblock %}

{% block publishStatus %}
    {{- include('@MauticCore/Helper/publishstatus_badge.html.twig', {'entity' : item}) -}}
{% endblock %}

{% block actions %}
    {{ include('@MauticCore/Helper/page_actions.html.twig', {
            'item': item,
            'templateButtons': {
                'edit': securityHasEntityAccess(permissions['bge:internalemail:editown'], permissions['bge:internalemail:editother'], item.createdBy),
                'clone': permissions['bge:internalemail:create'],
                'delete': securityHasEntityAccess(permissions['bge:internalemail:deleteown'], permissions['bge:internalemail:deleteother'], item.createdBy),
                'close': securityIsGranted('bge:internalemail:view'),
            },
            'routeBase': 'internalemail',
            'langVar': 'internalemail',
    }) }}
{% endblock %}

{% block content %}
    <!-- start: box layout -->
    <div class="box-layout">
        <!-- left section -->
        <div class="col-md-12 height-auto">
            <div>
                <!-- page detail header -->
                <div class="pr-md pl-md pt-lg pb-lg">
                    <div class="box-layout">
                        <div class="col-xs-10">
                            <div class="text-white dark-sm mb-0">{{ item.lead.primaryIdentifier }}</div>
                        </div>
                    </div>
                </div>
                <div class="collapse in" id="internalemail-details">
                    <div class="pr-md pl-md pb-md">
                        <div class="panel shd-none mb-0">
                            <table class="table table-hover mb-0">
                                <tbody>
                                    <tr>
                                        <td width="20%"><span class="fw-b textTitle">{% trans %}mautic.core.id{% endtrans %}</span></td>
                                        <td>{{ item.id }}</td>
                                    </tr>
                                    <tr>
                                        <td><span class="fw-b textTitle">{% trans %}mautic.core.name{% endtrans %}</span></td>
                                        <td>
                                            {% set flag = item.country is not empty ? assetGetCountryFlag(item.country|country_name) : '' %}
                                            {% if flag is not empty %}
                                                <img src="{{ flag }}" style="max-height: 24px;" class="mr-sm" />
                                            {% endif %}
                                            {{ item.country|country_name }}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span class="fw-b textTitle">{% trans %}mautic.core.description{% endtrans %}</span></td>
                                        <td>{{ item.language|language_name }}</td>
                                    </tr>
<tr>
                                        <td><span class="fw-b textTitle">{% trans %}mautic.core.category{% endtrans %}</span></td>
                                        <td>{{ item.category ? item.category.title : 'N/A' }}</td>
                                    </tr>                                 
                                    <tr>
                                        <td><span class="fw-b textTitle">{% trans %}mautic.core.dateadded{% endtrans %}</span></td>
                                        <td>{{ item.dateAdded|date('Y-m-d H:i') }}</td>
                                    </tr>                                    
                                    <tr>
                                        <td><span class="fw-b textTitle">{% trans %}mautic.core.datemodified{% endtrans %}</span></td>
                                        <td>{{ item.dateModified|date('Y-m-d H:i') }}</td>
                                    </tr>                                    
                                    <tr>
                                        <td><span class="fw-b textTitle">{% trans %}mautic.core.ispublished{% endtrans %}</span></td>
                                        <td>{{ item.isPublished ? 'Yes' : 'No' }}</td>
                                    </tr>                                    
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- end: box layout -->
{% endblock %}