<mjml>
  <mj-head>
	<!-- CSS-STYLE -->
	<mj-style inline="inline">
	  p, li { margin: 0 !important; padding: 0; line-height: 1.4em; }
	</mj-style>
  </mj-head>
  <!-- BODY -->
  <mj-body background-color="#ffffff">
	<mj-section background-color="#ffffff">
	  <mj-column>
		<mj-text font-size="11px" align="center" padding-top="0px" padding-bottom="15px">
		  <p>
			<span id="ituef" draggable="true" data-fr-verified="true" class="gjs-no-pointer">{trans_webview_text}</span>
		  </p>
		</mj-text>
		<mj-image src="https://news.bicgraphic.com/media/images/bge-logo.png" width="275px" padding-bottom="0px" href="https://elink.bicgraphic.com/site/%web_locale%"  alt="BIC Graphic">
		</mj-image>
		<mj-navbar>
		  <mj-navbar-link href="https://elink.bicgraphic.com/web/cat/101143/%web_locale%" font-size="12px">
			<p>{trans_products}
			</p>
		  </mj-navbar-link>
		  <mj-navbar-link href="https://elink.bicgraphic.com/web/content/100400/%web_locale%" font-size="12px">
			<p>{trans_sustainability}
			</p>
		  </mj-navbar-link>
		  <mj-navbar-link href="https://elink.bicgraphic.com/web/site/%web_locale%" font-size="12px">
			<p>{trans_brands}
			</p>
		  </mj-navbar-link>
		  <mj-navbar-link href="https://elink.bicgraphic.com/web/content/100006/%web_locale%" font-size="12px">
			<p>{trans_downloads}
			</p>
		  </mj-navbar-link>
		</mj-navbar>
	  </mj-column>
	</mj-section>
	<mj-section background-color="#ffffff">
	  <mj-column width="550px">
		<mj-text font-size="30px" align="center" font-weight="700">
		  <p>Your main headline goes here
		  </p>
		</mj-text>
		<mj-text font-size="16px" align="center">
		  <p>Use this space to build excitement about your new line. Explain the inspiration behind it, mention key pieces, and tell readers why they shouldn't miss out.
		  </p>
		</mj-text>
	  </mj-column>
	</mj-section>
	<mj-section background-color="#f4f4f4">
	  <mj-column>
		<mj-spacer>
		</mj-spacer>
		<mj-image src="/app/assets/images/placeholder-image.png">
		</mj-image>
			<mj-button href="https://example.com" color="#ffffff" background-color="#f39200" inner-padding="16px 32px" border-radius="20px 20px 20px 20px" font-size="16px">Button text here</mj-button>
		<mj-spacer>
		</mj-spacer>
	  </mj-column>
	  <mj-column>
		<mj-spacer>
		</mj-spacer>
		<mj-image src="/app/assets/images/placeholder-image.png">
		</mj-image>
			<mj-button href="https://example.com" color="#ffffff" background-color="#f39200" inner-padding="16px 32px" border-radius="20px 20px 20px 20px" font-size="16px">Button text here</mj-button>
		<mj-spacer>
		</mj-spacer>
	  </mj-column>
	</mj-section>
	<mj-section background-color="#f4f4f4">
	  <mj-column>
		<mj-spacer>
		</mj-spacer>
		<mj-image src="/app/assets/images/placeholder-image.png">
		</mj-image>
			<mj-button href="https://example.com" color="#ffffff" background-color="#f39200" inner-padding="16px 32px" border-radius="20px 20px 20px 20px" font-size="16px">Button text here</mj-button>
		<mj-spacer>
		</mj-spacer>
	  </mj-column>
	  <mj-column>
		<mj-spacer>
		</mj-spacer>
		<mj-image src="/app/assets/images/placeholder-image.png">
		</mj-image>
			<mj-button href="https://example.com" color="#ffffff" background-color="#f39200" inner-padding="16px 32px" border-radius="20px 20px 20px 20px" font-size="16px">Button text here</mj-button>
		<mj-spacer>
		</mj-spacer>
	  </mj-column>
	</mj-section>
	<mj-section background-color="#ffffff">
	  <mj-column width="550px">
		<mj-social font-size="12px" icon-size="30px" border-radius="12px" mode="horizontal">
		  <mj-social-element name="facebook-noshare" border-radius="14px 14px 14px 14px" padding-right="10px" color="#000000" background-color="#000000" href="https://www.facebook.com/bicgraphic">
		  </mj-social-element>
		  <mj-social-element name="linkedin-noshare" border-radius="14px 14px 14px 14px" padding-right="10px" padding-left="10px" color="#000000" background-color="#000000" href="https://www.linkedin.com/company/bic-graphic">
		  </mj-social-element>
		  <mj-social-element name="youtube" border-radius="14px 14px 14px 14px" padding-left="10px" color="#000000" background-color="#000000" href="https://www.youtube.com/channel/UC7ZQGQ44SlF34LsUvTIl1ZA">
		  </mj-social-element>
		  <mj-social-element name="instagram" border-radius="14px 14px 14px 14px" padding-left="10px" color="#000000" background-color="#000000" href="https://www.instagram.com/bicgraphic/">
		  </mj-social-element>
		</mj-social>
		<mj-text font-size="18px" align="center">
		  <p>
			<span style="font-size:22px;"><span id="ijgma" draggable="true" class="gjs-no-pointer"><strong>#ThinkBIC</strong></span></span>
			<br/>{trans_afterthinkBIC}
		  </p>
		</mj-text>
		<mj-text align="center">
		  <p>
			<span style="font-size:10px;"><span id="i8141" draggable="true" class="gjs-no-pointer">{trans_legal}</span></span>
		  </p>
		  <p>
			<span style="font-size:10px;"> </span>
		  </p>
		  <p>
			<span style="font-size:10px;"><span id="i2hqb" draggable="true" class="gjs-no-pointer">{trans_unsubscribe_text}</span></span>
		  </p>
		</mj-text>
	  </mj-column>
	</mj-section>
	<mj-section padding-top="0" background-color="#000000">
	  <mj-column>
		<mj-spacer>
		</mj-spacer>
		<mj-text line-height="1.5" align="center" padding-top="0px" padding-bottom="0px" font-size="12px" color="#ffffff">
		  <p>{trans_copyright}
		  </p>
		</mj-text>
	  </mj-column>
	</mj-section>
  </mj-body>
